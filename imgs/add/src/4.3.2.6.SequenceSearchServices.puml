@startuml 4_3_2_6_SequenceSearchServices
title Sequence — Búsqueda paginada de servicios con filtros (PUS-05)

skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam noteBackgroundColor #FFF8DC
skinparam ParticipantBackgroundColor #EAF3FF

actor "Cliente / Visitante" as Client
participant "Caddy Gateway" as Caddy
participant "MarketplaceController" as Ctrl
participant "SearchServicesUseCase" as UC
participant "ServiceSpecification\n(Domain)" as Spec
participant "ServiceRepository" as Repo
participant "JpaServiceRepository\n(Specification API)" as Jpa
database "marketplace_schema\n(PostgreSQL)" as DB

Client -> Caddy : GET /api/v1/marketplace/services\n?category=design&priceMin=10&priceMax=80\n&minRating=4&q=logo&page=0&size=12
Caddy -> Ctrl : forward request
note right of Ctrl
  Endpoint público:
  no requiere JWT.
end note

Ctrl -> UC : execute(SearchCriteria, Pageable)

UC -> Spec : build(criteria)
Spec --> UC : Specification<ServiceOffering>\n(category=AND price BETWEEN AND avg_rating>=4 AND title ILIKE %logo%)

UC -> Repo : findAll(spec, pageable)
Repo -> Jpa : findAll(spec, pageable)
Jpa -> DB : SELECT id,title,price,avg_rating,thumbnail\nFROM service_offerings\nWHERE category_id=? AND price BETWEEN ? AND ?\nAND avg_rating>=? AND title ILIKE ?\nAND unpublished_at IS NULL\nORDER BY avg_rating DESC, created_at DESC\nLIMIT 12 OFFSET 0
note right of DB
  Índices usados:
  - idx_service_category
  - idx_service_price
  - idx_service_rating
end note
DB --> Jpa : 12 rows
Jpa --> Repo : Page<ServiceOfferingProjection>
Repo --> UC : Page<ServiceOfferingProjection>

UC -> UC : map(projection -> ServiceCardDTO)
note right of UC
  ServiceCardDTO solo trae
  id, title, price, avgRating,
  thumbnail. No carga descripción
  ni media completa (QA-06).
end note

UC --> Ctrl : Page<ServiceCardDTO>
Ctrl --> Caddy : 200 OK\n{ content:[...12], page:0, totalPages:N }
Caddy --> Client : 200 OK

@enduml
