@startuml 4_3_1_6_DomainClasses
title Domain Class Diagram — Engagement Bounded Context

skinparam class {
  BackgroundColor #EAF3FF
  BorderColor #1F4E79
  ArrowColor #1F4E79
}
skinparam classAttributeIconSize 0
hide circle

package "engagement.domain" <<Frame>> {

  class ProjectRequest {
    - id : UUID
    - clientId : UUID  <<external>>
    - freelancerId : UUID  <<external>>
    - serviceOfferingId : UUID  <<external>>
    - proposedPrice : Money
    - estimatedDays : int
    - message : String
    - status : RequestStatus
    - createdAt : Instant
    + accept(freelancerId) : Agreement
    + reject(freelancerId, reason) : void
    + cancelByClient(clientId) : void
  }

  enum RequestStatus {
    PENDING
    ACCEPTED
    REJECTED
    CANCELLED
  }

  class Agreement {
    - id : UUID
    - projectRequestId : UUID
    - finalPrice : Money
    - deadline : LocalDate
    - signedAt : Instant
  }

  class Project {
    - id : UUID
    - agreementId : UUID
    - status : ProjectStatus
    - history : List<StatusChange>
    + transitionTo(newStatus, actorId, policy) : void
    + markDelivered(freelancerId) : void
    + markCompleted(clientId) : void
    + cancel(actorId) : void
  }

  enum ProjectStatus {
    STARTED
    IN_PROGRESS
    DELIVERED
    COMPLETED
    REVIEWED
    CANCELLED
  }

  class StatusChange {
    - from : ProjectStatus
    - to : ProjectStatus
    - actorId : UUID
    - changedAt : Instant
    - note : String
  }

  class Review {
    - id : UUID
    - projectId : UUID
    - clientId : UUID
    - rating : int  <<1..5>>
    - comment : String
    - createdAt : Instant
  }

  class PriceSuggestion {
    - serviceCategoryId : UUID
    - complexity : Complexity
    - estimatedHours : int
    - suggestedRange : MoneyRange
  }

  enum Complexity {
    LOW
    MEDIUM
    HIGH
  }

  class Money <<Value Object>> {
    - amount : BigDecimal
    - currency : String
  }

  class MoneyRange <<Value Object>> {
    - min : Money
    - max : Money
  }

  interface ProjectStatusPolicy <<Domain Service>> {
    + canTransition(from, to, actorRole) : boolean
  }

  interface PriceSuggestionPolicy <<Strategy>> {
    + suggest(input) : MoneyRange
  }

  class HourlyRatePolicy implements PriceSuggestionPolicy
  class CategoryBasedPolicy implements PriceSuggestionPolicy
  class ExperienceBasedPolicy implements PriceSuggestionPolicy
}

ProjectRequest "1" --> "0..1" Agreement : produces
Agreement "1" --> "1" Project : starts
Project "1" --> "*" StatusChange : history
Project "1" --> "0..1" Review : reviewed by
Project ..> ProjectStatusPolicy : <<uses>>
ProjectRequest ..> Money : <<uses>>
Agreement ..> Money : <<uses>>
PriceSuggestion ..> MoneyRange : <<uses>>

note right of ProjectRequest
  clientId, freelancerId y
  serviceOfferingId son IDs
  externos (no joins).
  Validados vía REST contra
  AccessProfileService y
  GigMarketplaceService.
end note

@enduml
