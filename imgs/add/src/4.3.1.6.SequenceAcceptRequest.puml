@startuml 4_3_1_6_SequenceAcceptRequest
title Sequence — Aceptar solicitud de contratación y crear proyecto (PUS-07)

skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam noteBackgroundColor #FFF8DC
skinparam ParticipantBackgroundColor #EAF3FF

actor Freelancer
participant "Caddy Gateway" as Caddy
participant "JwtAuthenticationFilter" as JWT
participant "EngagementController" as Ctrl
participant "RespondProjectRequestUseCase" as UC
participant "RequestRepository" as Repo
participant "Project (Domain)" as Project
participant "EventPublisher\n(Outbox)" as Outbox
database "engagement_schema\n(PostgreSQL)" as DB
queue "RabbitMQ\nengagement.events" as MQ
participant "ChatNotificationService" as Chat

Freelancer -> Caddy : PATCH /api/v1/engagement/requests/{id}\nAuthorization: Bearer <jwt>\n{ "decision": "ACCEPTED" }
Caddy -> JWT : forward request
JWT -> JWT : validar firma JWT, expiración
JWT -> Ctrl : userId = freelancerId
Ctrl -> UC : execute(requestId, freelancerId, ACCEPTED)

UC -> Repo : findById(requestId)
Repo -> DB : SELECT * FROM project_requests
DB --> Repo : ProjectRequest
Repo --> UC : ProjectRequest

alt freelancerId != request.freelancerId
  UC --> Ctrl : ForbiddenOwnershipException
  Ctrl --> Caddy : 403 Forbidden
  Caddy --> Freelancer : 403
else ownership válido
  UC -> Project : factory.fromAcceptedRequest(request)
  Project --> UC : new Project (status = STARTED)

  UC -> Repo : saveAgreement + saveProject + appendStatusHistory
  UC -> Outbox : append AgreementSigned
  Repo -> DB : transaction { agreements, projects, project_status_history, engagement_outbox }
  DB --> Repo : OK
  Repo --> UC : OK

  UC --> Ctrl : ProjectCreatedDTO
  Ctrl --> Caddy : 200 OK + body
  Caddy --> Freelancer : 200 OK
end

== Asíncrono — Outbox dispatcher ==
Outbox -> DB : SELECT pending FROM engagement_outbox
DB --> Outbox : eventos pendientes
Outbox -> MQ : publish AgreementSigned
MQ --> Outbox : ack
Outbox -> DB : UPDATE engagement_outbox SET dispatched_at = now()

MQ -> Chat : deliver AgreementSigned
note right of Chat
  Crea conversación 1:1
  entre cliente y freelancer
end note

@enduml
