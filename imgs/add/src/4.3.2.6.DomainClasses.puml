@startuml 4_3_2_6_DomainClasses
title Domain Class Diagram — Marketplace Bounded Context

skinparam class {
  BackgroundColor #EAF3FF
  BorderColor #1F4E79
  ArrowColor #1F4E79
}
skinparam classAttributeIconSize 0
hide circle

package "marketplace.domain" <<Frame>> {

  class ServiceOffering {
    - id : UUID
    - freelancerId : UUID  <<external>>
    - categoryId : UUID
    - title : String
    - description : String
    - price : Money
    - estimatedDays : int
    - thumbnail : String
    - createdAt : Instant
    - unpublishedAt : Instant?
    + update(patch) : void
    + unpublish(actorId) : void
    + isOwnedBy(userId) : boolean
  }

  class ServiceCategory {
    - id : UUID
    - slug : String
    - displayName : String
    - parentId : UUID?
  }

  class ServiceMedia {
    - id : UUID
    - serviceId : UUID
    - storageKey : String
    - mimeType : String
    - sizeBytes : long
    - uploadedAt : Instant
  }

  class FreelancerReputation {
    - freelancerId : UUID
    - avgRating : double
    - reviewCount : int
    - updatedAt : Instant
    + applyNewRating(rating : int) : void
    + {static} createInitial(freelancerId, rating) : FreelancerReputation
  }

  class AppliedReview <<Idempotency>> {
    - reviewId : UUID
    - freelancerId : UUID
    - appliedAt : Instant
  }

  class Money <<Value Object>> {
    - amount : BigDecimal
    - currency : String
  }

  interface ServiceSpecification <<Specification>> {
    + toPredicate(root, query, cb) : Predicate
  }

  class ByCategorySpec implements ServiceSpecification
  class ByPriceRangeSpec implements ServiceSpecification
  class ByMinRatingSpec implements ServiceSpecification
  class ByTitleLikeSpec implements ServiceSpecification
  class PublishedOnlySpec implements ServiceSpecification

  class SpecificationComposer {
    + and(spec1, spec2) : ServiceSpecification
    + build(criteria) : ServiceSpecification
  }
}

ServiceOffering "1" --> "1" ServiceCategory : belongsTo
ServiceOffering "1" --> "*" ServiceMedia : contains
ServiceOffering ..> Money : <<uses>>
FreelancerReputation "1" --> "*" AppliedReview : tracks (idempotency)

SpecificationComposer ..> ServiceSpecification : <<composes>>

note right of ServiceOffering
  freelancerId es ID externo
  validado vía REST contra
  AccessProfileService al
  publicar el servicio.
end note

note bottom of FreelancerReputation
  Read model materializado.
  Actualizado por
  OnReviewCreatedHandler al
  consumir ReviewCreated desde
  PullEngagementService.
end note

@enduml
