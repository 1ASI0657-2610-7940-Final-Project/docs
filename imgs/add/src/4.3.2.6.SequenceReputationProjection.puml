@startuml 4_3_2_6_SequenceReputationProjection
title Sequence — Proyección de reputación al recibir ReviewCreated

skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam noteBackgroundColor #FFF8DC
skinparam ParticipantBackgroundColor #EAF3FF

participant "PullEngagementService\n(Outbox dispatcher)" as Eng
queue "RabbitMQ\nengagement.events" as MQ
participant "RabbitReviewConsumer\n@RabbitListener" as Consumer
participant "OnReviewCreatedHandler" as Handler
participant "FreelancerReputation\n(Domain)" as Rep
participant "ReputationRepository" as Repo
database "marketplace_schema\n(PostgreSQL)" as DB

Eng -> MQ : publish ReviewCreated\n{ projectId, freelancerId, rating, createdAt }
MQ -> Consumer : deliver ReviewCreated
note right of Consumer
  At-least-once.
  El handler debe ser idempotente:
  reviewId se guarda en
  applied_reviews para deduplicar.
end note

Consumer -> Handler : handle(event)

Handler -> Repo : findByFreelancerId(freelancerId)
Repo -> DB : SELECT * FROM freelancer_reputation\nWHERE freelancer_id = ?
DB --> Repo : reputation (avg_rating, count) | null
Repo --> Handler : Optional<FreelancerReputation>

alt no existe aún
  Handler -> Rep : createInitial(freelancerId, rating)
else ya existe
  Handler -> Rep : applyNewRating(rating)
  note right of Rep
    avg = (avg * count + rating) / (count + 1)
    count = count + 1
  end note
end

Handler -> Repo : saveAndMarkApplied(reputation, reviewId)
Repo -> DB : UPSERT freelancer_reputation\n+ INSERT applied_reviews(reviewId)
DB --> Repo : OK
Repo --> Handler : OK

Handler --> Consumer : OK
Consumer -> MQ : ack

note over Consumer, DB
  Si la transacción falla, no hay ack.
  RabbitMQ reintenta más tarde.
  Si reviewId ya está en applied_reviews,
  el handler responde OK sin reaplicar.
end note

@enduml
