@startuml 4_3_1_6_ComponentView
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title PullEngagementService — Component View (C4 Level 3) — GigU

LAYOUT_WITH_LEGEND()

Person(client, "Cliente", "Contrata servicios freelance en GigU.")
Person(freelancer, "Freelancer (Estudiante)", "Acepta solicitudes y entrega proyectos.")

System_Boundary(gateway, "Caddy Gateway") {
  Container(caddy, "Caddy Reverse Proxy", "Caddy", "Termina TLS y enruta /api/v1/engagement/*")
}

System_Boundary(engagement, "PullEngagementService — Spring Boot") {
  Component(controller, "EngagementController", "Spring REST Controller", "Expone /api/v1/engagement/*: requests, projects, reviews, price-suggestions.")
  Component(jwtFilter, "JwtAuthenticationFilter", "Spring Security Filter", "Valida JWT emitido por AccessProfileService e inyecta userId autenticado.")

  Component(uc_request, "RequestProjectUseCase", "Application Service", "Crea ProjectRequest y publica ProjectRequestCreated.")
  Component(uc_respond, "RespondProjectRequestUseCase", "Application Service", "Acepta o rechaza la solicitud; emite AgreementSigned.")
  Component(uc_status, "UpdateProjectStatusUseCase", "Application Service", "Aplica máquina de estados; emite ProjectStatusChanged.")
  Component(uc_review, "SubmitReviewUseCase", "Application Service", "Crea reseña y emite ReviewCreated.")
  Component(uc_price, "SuggestPriceUseCase", "Application Service", "Coordina PriceSuggestionPolicy.")

  Component(domain_project, "Project / Agreement / ProjectRequest / Review", "Domain Aggregates", "Entidades + invariantes de negocio.")
  Component(policy_status, "ProjectStatusPolicy", "Domain Service", "Reglas de transición del proyecto.")
  Component(policy_price, "PriceSuggestionPolicy", "Domain Strategy", "Estrategias de pricing intercambiables.")

  Component(repo_port, "ProjectRepository / RequestRepository / ReviewRepository", "Application Ports", "Interfaces de persistencia.")
  Component(event_port, "EventPublisher", "Application Port", "Interfaz de publicación de eventos de dominio.")
  Component(lookup_port, "ProfileLookupClient / ServiceLookupClient", "Application Ports", "Interfaces hacia microservicios externos.")

  Component(repo_jpa, "Jpa*Repository", "Spring Data JPA", "Implementa los puertos sobre Supabase PostgreSQL.")
  Component(outbox, "OutboxScheduler + RabbitEventPublisher", "Spring @Scheduled + AMQP", "Outbox Pattern hacia RabbitMQ.")
  Component(rest_clients, "RestProfileLookupClient / RestServiceLookupClient", "WebClient", "Adaptadores HTTP hacia AccessProfileService y GigMarketplaceService.")
}

ContainerDb(db, "engagement_schema", "PostgreSQL (Supabase)", "Tablas: project_requests, agreements, projects, project_status_history, reviews, price_suggestions, engagement_outbox.")
ContainerQueue(rabbit, "RabbitMQ", "AMQP Broker", "Exchanges: engagement.events.")

System_Ext(access, "AccessProfileService", "Spring Boot — REST")
System_Ext(marketplace, "GigMarketplaceService", "Spring Boot — REST")
System_Ext(chat, "ChatNotificationService", "Spring Boot — consumidor de eventos")

Rel(client, caddy, "HTTPS")
Rel(freelancer, caddy, "HTTPS")
Rel(caddy, controller, "JSON / HTTPS", "/api/v1/engagement/*")

Rel(controller, jwtFilter, "Pasa request por filtro")
Rel(jwtFilter, controller, "Inyecta userId")

Rel(controller, uc_request, "PUS-06")
Rel(controller, uc_respond, "PUS-07")
Rel(controller, uc_status, "PUS-08")
Rel(controller, uc_review, "PUS-10")
Rel(controller, uc_price, "PUS-12")

Rel(uc_request, domain_project, "Crea ProjectRequest")
Rel(uc_respond, domain_project, "Crea Agreement + Project")
Rel(uc_status, policy_status, "Valida transición")
Rel(uc_status, domain_project, "Aplica nuevo estado")
Rel(uc_review, domain_project, "Crea Review")
Rel(uc_price, policy_price, "Selecciona estrategia")

Rel(uc_request, repo_port, "Persiste")
Rel(uc_respond, repo_port, "Persiste")
Rel(uc_status, repo_port, "Persiste")
Rel(uc_review, repo_port, "Persiste")

Rel(uc_request, event_port, "publish ProjectRequestCreated")
Rel(uc_respond, event_port, "publish AgreementSigned")
Rel(uc_status, event_port, "publish ProjectStatusChanged")
Rel(uc_review, event_port, "publish ReviewCreated")

Rel(uc_request, lookup_port, "Verifica freelancer + servicio")

Rel(repo_port, repo_jpa, "implementado por")
Rel(event_port, outbox, "implementado por")
Rel(lookup_port, rest_clients, "implementado por")

Rel(repo_jpa, db, "JDBC", "engagement_schema")
Rel(outbox, db, "Lee outbox")
Rel(outbox, rabbit, "AMQP publish")
Rel(rest_clients, access, "GET /users/{id}")
Rel(rest_clients, marketplace, "GET /services/{id}")
Rel(rabbit, chat, "Consumer subscription")

@enduml
