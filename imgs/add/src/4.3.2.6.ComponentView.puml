@startuml 4_3_2_6_ComponentView
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title GigMarketplaceService — Component View (C4 Level 3) — GigU

LAYOUT_WITH_LEGEND()

Person(visitor, "Visitante / Cliente", "Explora el catálogo de servicios.")
Person(freelancer, "Freelancer (Estudiante)", "Publica y mantiene sus servicios.")

System_Boundary(gateway, "Caddy Gateway") {
  Container(caddy, "Caddy Reverse Proxy", "Caddy", "Termina TLS y enruta /api/v1/marketplace/*")
}

System_Boundary(marketplace, "GigMarketplaceService — Spring Boot") {
  Component(controller, "MarketplaceController", "Spring REST Controller", "Expone /api/v1/marketplace/services, /categories, /media.")
  Component(jwtFilter, "JwtAuthenticationFilter", "Spring Security Filter", "JWT obligatorio en POST/PATCH/DELETE; opcional en GET públicos.")

  Component(uc_publish, "PublishServiceUseCase", "Application Service", "Crea ServiceOffering + sube media. PUS-04.")
  Component(uc_update, "UpdateServiceUseCase", "Application Service", "Edita servicio respetando ownership.")
  Component(uc_unpublish, "UnpublishServiceUseCase", "Application Service", "Soft delete del servicio.")
  Component(uc_search, "SearchServicesUseCase", "Application Service", "Compone Specifications y devuelve página de ServiceCardDTO. PUS-05.")
  Component(uc_detail, "GetServiceDetailUseCase", "Application Service", "Devuelve ServiceDetailDTO con media + reputación.")
  Component(uc_review, "OnReviewCreatedHandler", "Event Handler", "Actualiza freelancer_reputation al consumir ReviewCreated.")

  Component(domain_service, "ServiceOffering / ServiceCategory\nServiceMedia / FreelancerReputation", "Domain Aggregates", "Entidades + invariantes.")
  Component(spec, "ServiceSpecification", "Domain Specification", "Predicados componibles para filtros.")

  Component(repo_port, "ServiceRepository / CategoryRepository\nReputationRepository", "Application Ports", "Abstracciones de persistencia.")
  Component(media_port, "MediaStoragePort", "Application Port", "Abstracción de almacenamiento de binarios.")
  Component(event_port, "EventConsumer", "Application Port", "Abstracción de consumo de eventos.")

  Component(repo_jpa, "JpaServiceRepository\n(con Specification API)", "Spring Data JPA", "Implementa puertos sobre Supabase PostgreSQL.")
  Component(storage_adapter, "SupabaseStorageAdapter", "WebClient + S3-like API", "Implementa MediaStoragePort.")
  Component(rabbit_consumer, "RabbitReviewConsumer", "Spring AMQP @RabbitListener", "Suscribe a engagement.events y delega a OnReviewCreatedHandler.")
}

ContainerDb(db, "marketplace_schema", "PostgreSQL (Supabase)", "Tablas: service_categories, service_offerings, service_media, freelancer_reputation.")
ContainerDb(storage, "Supabase Storage", "Object Storage", "Bucket: service-media")
ContainerQueue(rabbit, "RabbitMQ", "AMQP Broker", "Exchange: engagement.events.")

System_Ext(engagement, "PullEngagementService", "Spring Boot — productor de ReviewCreated")

Rel(visitor, caddy, "HTTPS")
Rel(freelancer, caddy, "HTTPS")
Rel(caddy, controller, "JSON / HTTPS", "/api/v1/marketplace/*")

Rel(controller, jwtFilter, "Pasa request por filtro")
Rel(jwtFilter, controller, "Inyecta userId si existe")

Rel(controller, uc_publish, "PUS-04")
Rel(controller, uc_update, "PUS-04")
Rel(controller, uc_unpublish, "PUS-04")
Rel(controller, uc_search, "PUS-05")
Rel(controller, uc_detail, "PUS-05")

Rel(uc_publish, domain_service, "Crea ServiceOffering")
Rel(uc_update, domain_service, "Aplica cambios")
Rel(uc_unpublish, domain_service, "Marca unpublished_at")
Rel(uc_search, spec, "Compone filtros")
Rel(uc_search, repo_port, "Ejecuta query paginada")
Rel(uc_detail, repo_port, "Lee detalle")
Rel(uc_review, domain_service, "Actualiza FreelancerReputation")

Rel(uc_publish, repo_port, "Persiste")
Rel(uc_publish, media_port, "Sube binario")
Rel(uc_review, repo_port, "Persiste reputación")

Rel(repo_port, repo_jpa, "implementado por")
Rel(media_port, storage_adapter, "implementado por")
Rel(event_port, rabbit_consumer, "implementado por")

Rel(repo_jpa, db, "JDBC", "marketplace_schema")
Rel(storage_adapter, storage, "HTTPS upload/download")
Rel(rabbit_consumer, rabbit, "AMQP subscribe")
Rel(rabbit_consumer, uc_review, "Delega evento")
Rel(engagement, rabbit, "Publica ReviewCreated")

@enduml
